{
  "extends": "../tsconfig.json",
  "exclude": [],
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.ts",
    "**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "next.config.mjs",
    ".next/types/**/*.ts",
  ],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@payload-config": ["./payload.config.ts"],
      "@ace-ams/payload-syncer": ["../src/index.ts"],
      "@ace-ams/payload-syncer/client": ["../src/exports/client.ts"],
      "@ace-ams/payload-syncer/rsc": ["../src/exports/rsc.ts"],
    },
    "noEmit": true,
    "emitDeclarationOnly": false,
  },
}
